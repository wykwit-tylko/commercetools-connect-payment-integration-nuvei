{
  "name": "@nuvei-commercetools/connector",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "pnpm -r run build",
    "lint": "find processor/src enabler/src -name '*.ts' -not -path '*/node_modules/*' | xargs oxlint",
    "format": "oxfmt processor/src enabler/src",
    "test": "pnpm -r run test",
    "typecheck": "tsc --noEmit -p processor/tsconfig.json && tsc --noEmit -p enabler/tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "oxfmt": "^0.1.0",
    "oxlint": "^0.16.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "overrides": {
      "lodash": "4.18.1"
    }
  }
}
